# =============================================================
#  20fit Health Profile — Environment Variables
#  Copy file ini jadi ".env" (lokal) ATAU isi di Railway > Variables.
#  JANGAN commit file .env asli ke git.
# =============================================================

# ---- Supabase ----
SUPABASE_URL=https://cpvzwqptzcxnwzfzgrmt.supabase.co
# anon/public key (Supabase > Settings > API > anon public). AMAN dipublik.
SUPABASE_ANON_KEY=
# service_role key (Supabase > Settings > API > service_role). RAHASIA! server-only.
SUPABASE_SERVICE_KEY=

# ---- Email (SMTP) untuk kirim OTP ----
# Contoh Gmail: host smtp.gmail.com, port 465, secure true, user=email, pass=app password
# Kalau dikosongkan: OTP TIDAK terkirim ke email, hanya muncul di log server (mode tes).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=20fit <no-reply@20fit.id>

# ---- OTP ----
OTP_TTL_MINUTES=10
# Kode "sakti" opsional buat testing/admin. Kosongkan di produksi!
DEV_MASTER_OTP=

# ---- 20FIT Arena Open API (riwayat member: kelas/paket/venue) ----
# API key dari Admin Hub Arena. RAHASIA! server-only, JANGAN commit nilainya.
# Format: 20fit_live_xxxxxxxx...  (isi di Railway > Variables)
ARENA_API_KEY=
# Opsional override base URL (default sudah benar):
# ARENA_API_URL=https://cpvzwqptzcxnwzfzgrmt.supabase.co/functions/v1/arena-api

# ---- Beli paket scan (20FIT shop order / Xendit) ----
# Kosongkan kalau order pakai token login user. Isi kalau tim dev 20FIT
# bilang endpoint shop/order butuh token PARTNER khusus (Bearer).
FITCO_PARTNER_TOKEN=

# Kode payment_status 20FIT yang berarti LUNAS (untuk auto thank-you + isi kredit scan).
# Terdokumentasi hanya 5=Pending & 4=Expired; kode "paid" belum resmi. Deteksi utama
# tetap pakai teks status_description (paid/settled/success). Isi (mis. "1,3") HANYA kalau
# dev 20FIT sudah konfirmasi kode angkanya. Boleh dikosongkan.
FITCO_PAID_STATUS=

# ---- SingaPay Payment Gateway ----
# Base URL boleh publik (default sandbox). Client Secret / API Key / HMAC key RAHASIA —
# isi nilainya HANYA di Railway env, JANGAN di file yang ter-commit.
#   Sandbox: https://sandbox-payment-b2b.singapay.id | Production: https://payment-b2b.singapay.id
# SINGAPAY_BASE_URL=
SINGAPAY_CLIENT_ID=
SINGAPAY_CLIENT_SECRET=
SINGAPAY_API_KEY=
SINGAPAY_HMAC_KEY=
# Set "1" untuk MENOLAK webhook dgn signature invalid (401). Saat bring-up biarkan kosong/0:
# webhook tetap dibalas 200 + hasil verifikasi di-log, jadi tombol Test lolos & payload terlihat.
SINGAPAY_WEBHOOK_ENFORCE=

# ---- Fitco / 20FIT API (login, register, verifikasi email) ----
# URL bisa dipublik; TOKEN Bearer per-environment RAHASIA (lihat docs/GITHUB_SECRETS.md).
# Staging:    https://stagingapi.fitco.id   | Production: https://productionapi.fitco.id
# FITCO_API_URL=
# FITCO_SSO_URL=
# FITCO_LOGIN_PATH=
# FITCO_GOOGLE_LOGIN_PATH=/api/v1/auth/login/google

# ---- Login Google (Google Identity Services) ----
# Dari Google Cloud Console > APIs & Services > Credentials > OAuth client ID (tipe: Web application).
# Tombol "Login dengan Google" muncul kalau variabel di bawah terisi.
# Di Google Console, daftarkan "Authorized JavaScript origins" = origin situs
# (mis. https://my.20fit.id, https://profile20fit-staging.up.railway.app).
#
# Client ID — PUBLIK (boleh tampil di web). Client Secret TIDAK diperlukan untuk flow GIS.
# Ada default publik (Client ID web app 20FIT) di server.js, jadi tombol Google
# selalu tampil walau ini dikosongkan. Isi HANYA kalau mau override per environment.
GOOGLE_CLIENT_ID=

# ---- Partner API (profil member 20FIT) ----
# RAHASIA! server-only.
PARTNER_API_KEY=

# ---- Weather & AQI (widget cuaca dashboard) ----
# Token WAQI/AQICN. RAHASIA! server-only.
WAQI_TOKEN=

# ---- Admin ----
# Key akses halaman /api/admin/stats. RAHASIA! Wajib diisi kuat di produksi.
ADMIN_KEY=

# ---- Meta (Facebook) Pixel + Conversions API ----
# Pixel ID — PUBLIK (tampil di web). Ada default di server.js; isi untuk override.
META_PIXEL_ID=
# Access token Conversions API — RAHASIA! server-only, JANGAN commit nilainya.
# Dari Meta Events Manager > Settings > Conversions API > Generate access token.
META_CAPI_ACCESS_TOKEN=
# Versi Graph API (opsional, default sudah benar):
# META_CAPI_VERSION=v19.0

# ---- Lain ----
NODE_ENV=production
