# =============================================================
#  20fit Health Profile — Environment Variables
#  Copy file ini jadi ".env" (lokal) ATAU isi di Railway > Variables.
#  JANGAN commit file .env asli ke git.
# =============================================================

# ---- Supabase ----
SUPABASE_URL=https://cpvzwqptzcxnwzfzgrmt.supabase.co
# anon/public key (Supabase > Settings > API > anon public). AMAN dipublik.
SUPABASE_ANON_KEY=
# service_role key (Supabase > Settings > API > service_role). RAHASIA! server-only.
SUPABASE_SERVICE_KEY=

# ---- Email (SMTP) untuk kirim OTP ----
# Contoh Gmail: host smtp.gmail.com, port 465, secure true, user=email, pass=app password
# Kalau dikosongkan: OTP TIDAK terkirim ke email, hanya muncul di log server (mode tes).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=20fit <no-reply@20fit.id>

# ---- OTP ----
OTP_TTL_MINUTES=10
# Kode "sakti" opsional buat testing/admin. Kosongkan di produksi!
DEV_MASTER_OTP=

# ---- Lain ----
NODE_ENV=production
